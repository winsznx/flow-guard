# FlowGuard Backend Environment Variables
# Copy this file to .env for local development

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (Supabase Postgres)
# Pooler URL (port 6543) for runtime app queries
# DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL (port 5432) for schema migrations / DDL
# DIRECT_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL=
DIRECT_URL=

# Encryption key for airdrop/reward/bounty/grant authority private keys at rest.
# Required for any airdrop/reward/bounty/grant operation (create or claim).
# Generate with: openssl rand -hex 32
# WARNING: If this key is lost or rotated, all encrypted authority keys in the
# DB become unrecoverable. Store offline alongside your DB backup.
AIRDROP_CLAIM_KEY_ENCRYPTION_KEY=

# Optional: fee sponsor wallet (covers tx fees for users on claim flows).
# Hex private key (64 chars). Leave empty to disable sponsorship.
# BACKEND_FEE_PAYER_KEY_HEX=

# Bitcoin Cash Network Configuration
# Options: mainnet, chipnet (testnet)
BCH_NETWORK=chipnet

# Optional: Chaingraph URL for blockchain queries
# CHAINGRAPH_URL=http://localhost:3000

# Optional: admin-only data export endpoint protection (any random string)
# ADMIN_EXPORT_TOKEN=

# Funding output tuning (satoshis)
# Global default for token-bearing covenant outputs (module-specific vars override this)
TOKEN_CONTRACT_SATOSHIS=20000
# Dust used for token change outputs
TOKEN_OUTPUT_DUST_SATOSHIS=1000
# Optional module-specific overrides
# PAYMENT_TOKEN_CONTRACT_SATOSHIS=20000
# STREAM_TOKEN_CONTRACT_SATOSHIS=20000
# BUDGET_TOKEN_CONTRACT_SATOSHIS=20000
# AIRDROP_TOKEN_CONTRACT_SATOSHIS=20000
