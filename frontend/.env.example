# FlowGuard Frontend Environment Variables
# Copy this file to .env.local for local development

# Backend API URL
VITE_API_URL=https://flowguard-production.up.railway.app/api

# Bitcoin Cash Network
VITE_BCH_NETWORK=chipnet

# WalletConnect v2 Project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=demo-project-id

# Enable the WizardConnect connector tile in the wallet picker.
# WizardConnect is a BCH-native dapp-to-wallet protocol (NIP-17 over WebSocket).
# Currently only Paytaca mobile (v0.24.x+) ships support. Pre-1.0 with active
# churn — leave disabled in production unless you've smoke-tested against the
# Cauldron relay (wss://relay.cauldron.quest:443) with a real Paytaca session.
# Default: false.
VITE_ENABLE_WIZARDCONNECT=false
