{
  "name": "flowguard",
  "version": "0.1.0",
  "description": "Contract-backed treasuries, streams, payments, distributions, and governance on Bitcoin Cash",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "contracts",
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter './*' dev",
    "build": "pnpm --recursive build",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "//pnpm-overrides": "Force vulnerable transitive dependencies to patched versions. Each entry is justified in docs/internal/security/PACKAGE_UPDATES.md (gitignored). Major-version-bounded (e.g. ^0.1.13) where the host package depends on a specific major; loose >= where the consumer is major-stable.",
  "pnpm": {
    "overrides": {
      "tar": "^7.5.11",
      "qs": "^6.14.2",
      "path-to-regexp": "^0.1.13",
      "minimatch": "^9.0.7",
      "brace-expansion": "^2.0.3",
      "picomatch": "^4.0.4",
      "serialize-javascript": "^7.0.5",
      "flatted": "^3.4.2",
      "esbuild": "^0.25.0",
      "rollup": "^4.59.0",
      "postcss": "^8.5.10",
      "h3": "^1.15.9",
      "defu": "^6.1.5",
      "ajv": "^6.14.0",
      "bn.js": "^5.2.3",
      "@tootallnate/once": "^3.0.1",
      "uuid": "^14.0.0",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "ws@>=7.0.0 <7.5.11": "7.5.11"
    }
  }
}
